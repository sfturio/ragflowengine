FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml README.md ./
COPY app ./app
COPY frontend_streamlit.py ./

RUN pip install --no-cache-dir .

EXPOSE 8501

CMD ["python", "-m", "streamlit", "run", "frontend_streamlit.py", "--server.address", "0.0.0.0", "--server.port", "8501", "--server.headless", "true"]
